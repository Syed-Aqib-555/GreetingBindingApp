@page "/greeting-app"
@rendermode InteractiveServer

<PageTitle>Greeting Application</PageTitle>

<div class="main-container">
    <div class="greeting-card">
        <div class="header-section">
            <h1>User Greeting Application</h1>
            <p>
                Demonstration of One-Way and Two-Way Data Binding
            </p>
            <div class="input-section">
                <label class="input-label">
                    Enter Your Name
                </label>

                <!-- Two way data binding-->
                <input type="text"
                       class="custom-input"
                       placeholder="Type your full name..."
                       @bind="UserName" />

            </div>

            <div class="output-section">
                <h3>
                    Greeting Message
                </h3>

                <!-- One way data binding -->
                <div class="message-box">
                    @GreetingMessage
                </div>
            </div>

            <div class="info-section">
                <div class="info-card">
                    <h4>
                        Two-Way data Binding
                    </h4>
                    <p>
                        The <code>@@bind</code> directive automatically updates the
                        <strong>UserName</strong> variable whenever the user types
                        inside the textbox.
                    </p>
                </div>

                <h4>
                    One-Way data Binding
                </h4>
                <p>
                    The greeting message is displayed using one-way binding,
                    where data flows from the component to the UI only.
                </p>
            </div>
        </div>
    </div>
</div>

@code{
    //variable of two way binding
    private string UserName = "";

    //property of one way binding
    private string GreetingMessage => string.IsNullOrWhiteSpace(UserName)
        ? "Please enter your name to continue."
        : $"Welcome, {UserName}! Hope you have a productive day.";
}